{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://if-letters-home-could-sing.invalid/contracts/v1/installation-export.schema.json",
  "title": "Pseudonymous installation research export",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "export_id",
    "session_id",
    "consent_version",
    "relative_time_origin",
    "duration_ms",
    "heart_rate",
    "interaction_events"
  ],
  "properties": {
    "schema_version": {"const": "1"},
    "export_id": {"type": "string", "minLength": 1, "maxLength": 80},
    "session_id": {
      "type": "string",
      "pattern": "^(?:fixture-session-[a-z0-9-]+|session-[0-9a-f]{32})$"
    },
    "consent_version": {"type": "string", "pattern": "^consent-v[0-9]+$"},
    "relative_time_origin": {"const": "first-accepted-ink"},
    "duration_ms": {"type": "integer", "minimum": 0},
    "heart_rate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["samples", "gaps"],
      "properties": {
        "samples": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["elapsed_ms", "bpm", "quality", "source_clock_offset_ms"],
            "properties": {
              "elapsed_ms": {"type": "integer"},
              "bpm": {"type": "integer", "minimum": 1, "maximum": 250},
              "quality": {
                "type": "array",
                "minItems": 1,
                "items": {"type": "string", "minLength": 1, "maxLength": 40}
              },
              "source_clock_offset_ms": {"type": "integer"}
            }
          }
        },
        "gaps": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["started_elapsed_ms", "ended_elapsed_ms", "reason"],
            "properties": {
              "started_elapsed_ms": {"type": "integer"},
              "ended_elapsed_ms": {"type": "integer"},
              "reason": {"type": "string", "minLength": 1, "maxLength": 40}
            }
          }
        }
      }
    },
    "interaction_events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["elapsed_ms", "event"],
        "properties": {
          "elapsed_ms": {"type": "integer"},
          "event": {
            "enum": [
              "biometric-consent-granted",
              "biometric-consent-declined",
              "first-ink",
              "heart-rate-gap",
              "submit",
              "marginalia-viewed"
            ]
          }
        }
      }
    }
  }
}
