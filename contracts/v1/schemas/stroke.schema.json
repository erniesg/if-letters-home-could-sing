{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://if-letters-home-could-sing.invalid/contracts/v1/stroke.schema.json",
  "title": "Accepted reply stroke",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "stroke_id", "accepted_at", "points"],
  "properties": {
    "schema_version": {"const": "1"},
    "stroke_id": {"type": "string", "minLength": 1},
    "accepted_at": {"type": "string", "format": "date-time"},
    "points": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["x", "y"],
        "properties": {
          "x": {"type": "number", "minimum": 0, "maximum": 1},
          "y": {"type": "number", "minimum": 0, "maximum": 1},
          "pressure": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    }
  }
}
