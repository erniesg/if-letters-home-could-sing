{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://if-letters-home-could-sing.invalid/contracts/v1/review.schema.json",
  "title": "Reversible marginalia overlay",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_id",
    "session_id",
    "reviewer",
    "status",
    "summary",
    "annotations"
  ],
  "properties": {
    "schema_version": {"const": "1"},
    "review_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "session_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "reviewer": {"type": "string", "minLength": 1, "maxLength": 64},
    "status": {
      "enum": ["reviewed", "empty", "non-chinese", "mixed-language", "illegible"]
    },
    "summary": {"type": "string", "minLength": 1, "maxLength": 280},
    "annotations": {
      "type": "array",
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "anchor", "message", "confidence"],
        "properties": {
          "id": {"type": "string", "minLength": 1, "maxLength": 64},
          "kind": {"enum": ["correction", "uncertain-reading", "affirmation", "tone", "reflection"]},
          "anchor": {
            "type": "object",
            "additionalProperties": false,
            "required": ["page", "x", "y", "width", "height"],
            "properties": {
              "page": {"const": 2},
              "x": {"type": "number", "minimum": 0, "maximum": 1},
              "y": {"type": "number", "minimum": 0, "maximum": 1},
              "width": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
              "height": {"type": "number", "exclusiveMinimum": 0, "maximum": 1}
            }
          },
          "message": {"type": "string", "minLength": 1, "maxLength": 180},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    }
  }
}
